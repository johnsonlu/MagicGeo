# API configuration (OpenAI-compatible)
API_KEY=your_api_key_here
BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-v4-flash

# Coordinate assignment engine: brute_force (default) or nelder_mead
COORDINATE_ENGINE=nelder_mead
COORDINATE_ENGINE_TIMEOUT=600
COORDINATE_LOW=-2
COORDINATE_HIGH=2
NELDER_MEAD_RESTARTS=8
NELDER_MEAD_MAXITER=2000
BOOLEAN_PENALTY=1000
